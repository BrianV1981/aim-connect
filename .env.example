# ==========================================
# A.I.M. CONNECT - ENVIRONMENT VARIABLES
# ==========================================

# (Required for Ngrok Tunnel)
# Revoke your old token and get a new one from dashboard.ngrok.com
NGROK_AUTHTOKEN="your_ngrok_authtoken_here"

# (Optional) Set a static Ngrok domain (e.g. your-name.ngrok-free.dev)
# If left blank, ngrok will assign a random ephemeral URL.
NGROK_DOMAIN=""

# (Optional) Define the absolute path for the Web IDE Workspace.
# Defaults to the user's home directory (~) if omitted.
AIM_WORKSPACE="/home/user/my-projects"

# (Optional) Comma-separated list of allowed CORS origins for the FastAPI backend.
# Defaults to "*" (allow all) which is acceptable if running behind a secure Ngrok tunnel.
CORS_ORIGINS="*"
ALLOWED_IPS="" # Optional: Comma-separated list of allowed IP addresses
